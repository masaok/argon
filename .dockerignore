# Dependencies — always installed fresh inside the image for a
# deterministic, platform-correct build (native deps compile in-container).
node_modules
**/node_modules

# Build outputs — regenerated by `pnpm build`
**/dist
**/.next
**/.turbo

# Version control & CI
.git
.gitignore
.github

# Local env & secrets — provided at runtime, never baked into the image
.env
.env.*

# Logs & OS cruft
*.log
**/*.log
.DS_Store

# Docker files themselves don't need to be in the context
docker-compose.yml
